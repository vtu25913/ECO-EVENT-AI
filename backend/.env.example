# =============================================================================
# EcoEvent AI - Backend Environment Configuration
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Supabase (Database) ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=your-jwt-secret

# ─── IBM BOB / AI Integration ────────────────────────────────────────────────
# To enable genuine AI-powered responses in the Sustainability Advisor chatbot,
# configure one of the supported AI providers below.
#
# When configured, the backend will call the AI API for sustainability questions.
# When not configured, the backend falls back to built-in hardcoded responses.

# Provider: 'openai' (default) or 'watsonx'
IBM_BOB_PROVIDER=openai

# API Key for the AI provider
# For OpenAI: Your OpenAI API key (sk-...)
# For watsonx: Your IBM Cloud API key
IBM_BOB_API_KEY=

# Custom API endpoint (optional, has defaults per provider)
# OpenAI default: https://api.openai.com/v1/chat/completions
# watsonx default: https://us-south.ml.cloud.ibm.com/ml/v1/text/generation
IBM_BOB_API_URL=

# Model to use (optional, has defaults per provider)
# OpenAI default: gpt-4o-mini
# watsonx default: ibm/granite-3-8b-instruct
IBM_BOB_MODEL=

# watsonx-specific: Project ID (required for watsonx provider)
# Find this in your watsonx.ai project settings
IBM_BOB_PROJECT_ID=

# ─── Examples ────────────────────────────────────────────────────────────────
#
# Example 1: OpenAI (simplest - just an API key)
#   IBM_BOB_PROVIDER=openai
#   IBM_BOB_API_KEY=sk-your-openai-key-here
#
# Example 2: IBM watsonx.ai
#   IBM_BOB_PROVIDER=watsonx
#   IBM_BOB_API_KEY=your-ibm-cloud-api-key
#   IBM_BOB_PROJECT_ID=your-watsonx-project-id
#   IBM_BOB_MODEL=ibm/granite-3-8b-instruct
#
# Note: When IBM_BOB_API_KEY is empty, the chatbot uses built-in knowledge
# responses for all questions without making any external API calls.
